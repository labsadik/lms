rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Live Chat: Supabase handles Auth, Firebase handles real-time sync.
    // The {document=**} recursively allows reading/writing the parent document 
    // AND all subcollections (like /messages) inside it.
    match /live_chats/{document=**} {
      allow read: if true;        // Anyone can read messages
      allow create: if true;      // React component enforces Supabase login before creating
      allow update, delete: if false; // No editing or deleting chat messages
    }
    
  }
}